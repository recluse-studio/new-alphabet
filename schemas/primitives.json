          "rail",
          "detail",
          "action_band"
        ]
      },
      {
        "name": "placement",
        "values": [
          "lead",
          "main",
          "support",
          "rail_start",
          "rail_end",
          "detail",
          "action_band"
        ]
      },
      {
        "name": "tag",
        "values": [
          "main",
          "section",
          "aside",
          "nav",
          "header"
        ]
      }
