      "density",
      "intent"
    ],
    "finite_options": [
      {
        "name": "density",
        "values": [
          "density.calm",
          "density.regular",
          "density.dense"
        ]
      },
      {
        "name": "intent",
        "values": [
          "editorial",
          "workspace"
        ]
      }
    ],
    "composition_notes": [
