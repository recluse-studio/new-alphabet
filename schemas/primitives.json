    "finite_options": [
      {
        "name": "intent",
        "values": [
          "editorial",
          "workspace"
        ]
      }
    ],
    "composition_notes": [
      "PageGrid must contain a named main region and may support rails, detail, or action bands."
    ],
    "example_ids": [
      "EditorialStructureExample",
      "WorkflowStructureExample"
    ]
  },
  {
